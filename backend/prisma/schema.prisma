// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id                        String   @id @default(uuid())
  email                     String   @unique
  password                  String
  name                      String?
  role                      Role     @default(USER)
  passwordResetToken        String?
  passwordResetExpiresAt    DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  sessions     Session[]
  progress     Progress[]
  scores       Score[]
  applications Application[]
  gigs         Gig[]
  savedTerms   SavedGlossaryTerm[]
  readingItems ReadingProgress[]
  quizAttempts QuizAttempt[]
  quizRetakeAccess QuizRetakeUnlock[] @relation("QuizRetakeLearner")
  quizRetakeUnlocksGranted QuizRetakeUnlock[] @relation("QuizRetakeAdmin")
  assignmentSubmissions AssignmentSubmission[]
  assignmentFeedbackGiven AssignmentFeedback[] @relation("AssignmentFeedbackReviewer")
  weekProgress WeekProgress[]
  coursesCreated  Course[]         @relation("CourseCreator")
  courseApprovals CourseApproval[] @relation("CourseApprovalReviewer")
  courseEnrollments CourseEnrollment[]
  profile      UserProfile?

  @@index([email])
  @@map("users")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// ─── User Profile (onboarding data) ──────────────────────────────────────────

model UserProfile {
  id                  String    @id @default(uuid())
  userId              String    @unique
  userRole            String?
  gender              String?
  country             String?
  experienceLevel     String?
  motivation          String?
  learningInterests   String[]  @default([])
  telegramHandle      String?
  twitterHandle       String?
  onboardingCompleted Boolean   @default(false)
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ─── Session (anonymous + authenticated) ─────────────────────────────────────

model Session {
  id        String   @id @default(uuid())
  userId    String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  scores Score[]

  @@index([userId])
  @@map("sessions")
}

// ─── Academy ─────────────────────────────────────────────────────────────────

model Course {
  id                String       @id @default(uuid())
  title             String
  description       String
  tagline           String?
  level             String?
  estimatedDuration String?
  phaseLabel        String?
  heroImage         String?
  contentUnit       String       @default("Lesson")
  slug              String       @unique
  published         Boolean      @default(false)
  publishedAt       DateTime?
  status            CourseStatus @default(DRAFT)
  createdById       String?
  approvalNotes     String?
  submittedAt       DateTime?
  approvedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  modules            Module[]
  weeks              Week[]
  createdBy          User?               @relation("CourseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  courseFacilitators CourseFacilitator[]
  approvals          CourseApproval[]
  enrollments        CourseEnrollment[]

  @@index([createdById])
  @@map("courses")
}

model CourseEnrollment {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("course_enrollments")
}

model CourseFacilitator {
  id            String @id @default(uuid())
  courseId      String
  facilitatorId String
  position      Int

  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  facilitator Facilitator @relation(fields: [facilitatorId], references: [id], onDelete: Cascade)

  @@unique([courseId, facilitatorId])
  @@index([courseId])
  @@index([facilitatorId])
  @@map("course_facilitators")
}

model CourseApproval {
  id         String         @id @default(uuid())
  courseId   String
  reviewerId String
  action     ApprovalAction
  notes      String?
  createdAt  DateTime       @default(now())

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviewer User   @relation("CourseApprovalReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([reviewerId])
  @@map("course_approvals")
}

model Module {
  id          String  @id @default(uuid())
  title       String
  description String?
  position    Int
  courseId    String

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  weeks   Week[]

  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  content     String
  videoUrl    String?
  duration    Int      // minutes
  position    Int
  moduleId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress  Progress[]

  @@index([moduleId])
  @@map("lessons")
}

model Progress {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("progress")
}

model Facilitator {
  id           String            @id @default(uuid())
  name         String
  title        String
  organization String
  email        String
  linkedinUrl  String
  photoUrl     String?
  bio          String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  weeks   WeekFacilitator[]
  courses CourseFacilitator[]

  @@unique([email])
  @@map("facilitators")
}

model Week {
  id                         String          @id @default(uuid())
  courseId                   String
  moduleId                   String?
  number                     Int
  title                      String
  slug                       String          @unique
  durationLabel              String
  difficulty                 WeekDifficulty
  hook                       String
  whatToExpect               String
  summary                    String
  estimatedCompletionMinutes Int
  videoTitle                 String?
  videoUrl                   String?
  lessonContent              String?
  published                  Boolean         @default(false)
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  course         Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module         Module?                 @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  facilitators   WeekFacilitator[]
  topics         WeekTopic[]
  objectives     WeekObjective[]
  slideDeck      SlideDeck?
  glossaryTerms  GlossaryTerm[]
  readingResources ReadingResource[]
  quiz           Quiz?
  assignments    Assignment[]
  progress       WeekProgress[]
  images         WeekImage[]
  videos         WeekVideo[]

  @@unique([courseId, number])
  @@index([courseId])
  @@index([moduleId])
  @@map("weeks")
}

model WeekVideo {
  id          String  @id @default(uuid())
  weekId      String
  title       String
  url         String
  description String?
  position    Int

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([weekId, position])
  @@index([weekId])
  @@map("week_videos")
}

model WeekImage {
  id       String  @id @default(uuid())
  weekId   String
  url      String
  alt      String?
  caption  String?
  position Int

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@index([weekId])
  @@map("week_images")
}

model WeekFacilitator {
  id            String      @id @default(uuid())
  weekId         String
  facilitatorId  String
  position       Int

  week        Week        @relation(fields: [weekId], references: [id], onDelete: Cascade)
  facilitator Facilitator @relation(fields: [facilitatorId], references: [id], onDelete: Cascade)

  @@unique([weekId, facilitatorId])
  @@index([weekId])
  @@index([facilitatorId])
  @@map("week_facilitators")
}

model WeekTopic {
  id       String @id @default(uuid())
  weekId    String
  title    String
  position Int

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([weekId, position])
  @@index([weekId])
  @@map("week_topics")
}

model WeekObjective {
  id        String @id @default(uuid())
  weekId     String
  body      String
  position  Int

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([weekId, position])
  @@index([weekId])
  @@map("week_objectives")
}

model SlideDeck {
  id            String              @id @default(uuid())
  weekId         String              @unique
  title         String
  url           String
  slideCount    Int
  lastUpdatedAt DateTime
  viewerType    SlideDeckViewerType @default(EXTERNAL)

  week     Week               @relation(fields: [weekId], references: [id], onDelete: Cascade)
  sections SlideDeckSection[]

  @@map("slide_decks")
}

model SlideDeckSection {
  id          String @id @default(uuid())
  slideDeckId  String
  label       String
  position    Int

  slideDeck SlideDeck @relation(fields: [slideDeckId], references: [id], onDelete: Cascade)

  @@unique([slideDeckId, position])
  @@index([slideDeckId])
  @@map("slide_deck_sections")
}

model GlossaryTerm {
  id         String @id @default(uuid())
  weekId      String
  term       String
  definition String
  example    String?
  position   Int

  week       Week                @relation(fields: [weekId], references: [id], onDelete: Cascade)
  savedBy    SavedGlossaryTerm[]

  @@unique([weekId, term])
  @@unique([weekId, position])
  @@index([weekId])
  @@map("glossary_terms")
}

model SavedGlossaryTerm {
  id        String   @id @default(uuid())
  userId    String
  termId    String
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  term GlossaryTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([userId, termId])
  @@index([userId])
  @@index([termId])
  @@map("saved_glossary_terms")
}

model ReadingResource {
  id          String              @id @default(uuid())
  weekId       String
  title       String
  source      String
  url         String
  description String
  type        ReadingResourceType
  position    Int

  week     Week              @relation(fields: [weekId], references: [id], onDelete: Cascade)
  progress ReadingProgress[]

  @@unique([weekId, position])
  @@index([weekId])
  @@map("reading_resources")
}

model ReadingProgress {
  id         String   @id @default(uuid())
  userId     String
  resourceId String
  readAt     DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource ReadingResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
  @@map("reading_progress")
}

model Quiz {
  id            String   @id @default(uuid())
  weekId         String   @unique
  title         String
  passMark      Int      @default(70)
  attemptLimit  Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  week      Week               @relation(fields: [weekId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
  unlocks   QuizRetakeUnlock[]

  @@map("quizzes")
}

model QuizQuestion {
  id          String @id @default(uuid())
  quizId       String
  prompt      String
  explanation String
  position    Int

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]
  answers QuizAnswer[]

  @@unique([quizId, position])
  @@index([quizId])
  @@map("quiz_questions")
}

model QuizOption {
  id         String  @id @default(uuid())
  questionId  String
  label      String
  isCorrect  Boolean @default(false)
  position   Int

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers   QuizAnswer[]

  @@unique([questionId, position])
  @@index([questionId])
  @@map("quiz_options")
}

model QuizAttempt {
  id          String            @id @default(uuid())
  userId      String
  quizId      String
  score       Int
  percentage  Float
  status      QuizAttemptStatus @default(SUBMITTED)
  submittedAt DateTime          @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@unique([userId, quizId, submittedAt])
  @@index([userId])
  @@index([quizId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id               String @id @default(uuid())
  attemptId         String
  questionId        String
  selectedOptionId  String

  attempt        QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuizOption   @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@index([selectedOptionId])
  @@map("quiz_answers")
}

model QuizRetakeUnlock {
  id           String   @id @default(uuid())
  quizId        String
  userId        String
  unlockedById  String
  unlockedAt    DateTime @default(now())

  quiz       Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user       User @relation("QuizRetakeLearner", fields: [userId], references: [id], onDelete: Cascade)
  unlockedBy User @relation("QuizRetakeAdmin", fields: [unlockedById], references: [id], onDelete: Cascade)

  @@unique([quizId, userId])
  @@index([quizId])
  @@index([userId])
  @@index([unlockedById])
  @@map("quiz_retake_unlocks")
}

model Assignment {
  id                  String   @id @default(uuid())
  weekId               String
  title               String
  instructions        String
  deadline            DateTime
  allowTextSubmission Boolean  @default(true)
  allowFileUpload     Boolean  @default(false)
  position            Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  week        Week                  @relation(fields: [weekId], references: [id], onDelete: Cascade)
  choices     AssignmentChoice[]
  submissions AssignmentSubmission[]

  @@unique([weekId, position])
  @@index([weekId])
  @@map("assignments")
}

model AssignmentChoice {
  id           String @id @default(uuid())
  assignmentId  String
  title        String
  description  String
  position     Int

  assignment  Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@unique([assignmentId, position])
  @@index([assignmentId])
  @@map("assignment_choices")
}

model AssignmentSubmission {
  id                String                     @id @default(uuid())
  userId            String
  assignmentId      String
  choiceId          String?
  textResponse      String?
  attachmentName    String?
  attachmentUrl     String?
  attachmentMimeType String?
  attachmentSizeBytes Int?
  status            AssignmentSubmissionStatus @default(SUBMITTED)
  submittedAt       DateTime                   @default(now())
  reviewedAt        DateTime?

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  choice     AssignmentChoice? @relation(fields: [choiceId], references: [id], onDelete: SetNull)
  feedback   AssignmentFeedback[]

  @@index([userId])
  @@index([assignmentId])
  @@index([choiceId])
  @@map("assignment_submissions")
}

model AssignmentFeedback {
  id           String   @id @default(uuid())
  submissionId  String
  reviewerId    String
  feedback     String
  rating       Int?
  createdAt    DateTime @default(now())

  submission AssignmentSubmission          @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User                          @relation("AssignmentFeedbackReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([reviewerId])
  @@map("assignment_feedback")
}

model WeekProgress {
  id                  String             @id @default(uuid())
  userId              String
  weekId              String
  status              WeekProgressStatus @default(NOT_STARTED)
  quizSubmitted       Boolean            @default(false)
  assignmentSubmitted Boolean            @default(false)
  completedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([userId, weekId])
  @@index([userId])
  @@index([weekId])
  @@map("week_progress")
}

// ─── Games ────────────────────────────────────────────────────────────────────

model Score {
  id        String   @id @default(uuid())
  sessionId String
  gameId    String
  score     Int
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId  String?

  @@index([sessionId])
  @@index([gameId])
  @@index([userId])
  @@map("scores")
}

// ─── BlockGigs ────────────────────────────────────────────────────────────────

model Gig {
  id          String      @id @default(uuid())
  title       String
  description String
  budget      Float
  budgetType  BudgetType  @default(FIXED)
  currency    Currency    @default(USDC)
  category    String
  skills      String[]
  difficulty  Difficulty  @default(MID)
  deadline    String
  remote      Boolean     @default(true)
  featured    Boolean     @default(false)
  status      GigStatus   @default(OPEN)
  posterId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  poster       User          @relation(fields: [posterId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([posterId])
  @@index([status])
  @@index([category])
  @@map("gigs")
}

model Application {
  id        String            @id @default(uuid())
  gigId     String
  userId    String
  proposal  String
  rate      Float?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  gig  Gig  @relation(fields: [gigId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gigId, userId])
  @@index([gigId])
  @@index([userId])
  @@map("applications")
}

enum BudgetType {
  FIXED
  HOURLY
}

enum Currency {
  ETH
  USDC
  MATIC
}

enum Difficulty {
  ENTRY
  MID
  SENIOR
}

enum GigStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum WeekDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SlideDeckViewerType {
  MODAL
  EXTERNAL
}

enum ReadingResourceType {
  ARTICLE
  COURSE
  DOCUMENTATION
  WHITEPAPER
  VIDEO
  INTERACTIVE
}

enum QuizAttemptStatus {
  SUBMITTED
}

enum AssignmentSubmissionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum WeekProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum CourseStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ApprovalAction {
  APPROVED
  REJECTED
}
